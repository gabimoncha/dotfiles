[user]
	name = gabimoncha
	email = 39256258+gabimoncha@users.noreply.github.com
[core]
	ignorecase = false
[push]
	autoSetupRemote = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[init]
	defaultBranch = main
[include]
	path = ~/.gitconfig.local
