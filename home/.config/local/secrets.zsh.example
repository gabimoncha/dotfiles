# Local shell secrets.
#
# Copy this file to `secrets.zsh` in this directory, or keep using
# `~/.config/local/secrets.zsh`. Real `*.zsh` files are intentionally ignored.

# Infisical service tokens for shell wrappers.
export INFISICAL_WORK_TOKEN='st...'
export INFISICAL_PERSONAL_CLIENT_ID='st...'
export INFISICAL_PERSONAL_CLIENT_SECRET='st...'
export INFISICAL_PERSONAL_TOKEN='st...'

# Optional Infisical API URLs for non-default regions or self-hosted instances.
export INFISICAL_WORK_API_URL='https://app.infisical.com/api'
export INFISICAL_PERSONAL_API_URL='https://app.infisical.com/api'

# Context7 higher rate-limit token.
export CONTEXT7_API_KEY='...'

# Upstash credentials. Use the variables required by the tool or SDK you are using.
export UPSTASH_API_KEY='...'
export UPSTASH_EMAIL='...'
export UPSTASH_REDIS_REST_URL='https://...upstash.io'
export UPSTASH_REDIS_REST_TOKEN='...'
