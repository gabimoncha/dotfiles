// Place your key bindings in this file to override the defaults
[
  {
    "key": "shift+cmd+c cmd+l",
    "command": "editor.action.insertSnippet",
    "when": "editorTextFocus",
    "args": {
      "snippet": "console.log('${TM_SELECTED_TEXT}:', ${TM_SELECTED_TEXT})$0;"
    }
  },
  {
    "key": "cmd+shift+c cmd+j",
    "command": "editor.action.insertSnippet",
    "when": "editorTextFocus",
    "args": {
      "snippet": "console.log(JSON.stringify(${TM_SELECTED_TEXT}$1, null, 2))$0;"
    }
  },
  {
    "key": "cmd+down",
    "command": "terminal.focus"
  },
  {
    "key": "cmd+down",
    "command": "-workbench.action.terminal.focus",
    "when": "accessibilityModeEnabled && accessibleViewOnLastLine && terminalHasBeenCreated && accessibleViewCurrentProviderId == 'terminal' || accessibilityModeEnabled && accessibleViewOnLastLine && terminalProcessSupported && accessibleViewCurrentProviderId == 'terminal'"
  },
  {
    "key": "cmd+down cmd+w",
    "command": "workbench.action.terminal.killAll"
  },
  {
    "key": "cmd+w",
    "command": "-workbench.action.terminal.killEditor",
    "when": "terminalEditorFocus && terminalFocus && terminalHasBeenCreated && resourceScheme == 'vscode-terminal' || terminalEditorFocus && terminalFocus && terminalProcessSupported && resourceScheme == 'vscode-terminal'"
  },
  {
    "key": "ctrl+alt+cmd+left",
    "command": "workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "cmd+r shift+cmd+left",
    "command": "-workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "cmd+r shift+cmd+right",
    "command": "-workbench.action.moveEditorRightInGroup"
  },
  {
    "key": "shift+cmd+,",
    "command": "-editor.action.inPlaceReplace.up",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "shift+cmd+,",
    "command": "workbench.action.openGlobalSettingsCursorAlias"
  },
  {
    "key": "cmd+r cmd+\\",
    "command": "-workbench.action.splitEditorUp"
  },
  {
    "key": "cmd+r cmd+\\",
    "command": "-workbench.action.splitEditorRight"
  },
  {
    "key": "cmd+r cmd+\\",
    "command": "-workbench.action.splitEditorLeft"
  },
  {
    "key": "cmd+r cmd+\\",
    "command": "-workbench.action.splitEditorDown"
  },
  {
    "key": "cmd+r cmd+\\",
    "command": "-workbench.action.splitEditorOrthogonal"
  },
  {
    "key": "cmd+r right",
    "command": "-workbench.action.moveActiveEditorGroupRight"
  },
  {
    "key": "cmd+r down",
    "command": "-views.moveViewDown",
    "when": "focusedView != ''"
  },
  {
    "key": "cmd+r left",
    "command": "-views.moveViewLeft",
    "when": "focusedView != ''"
  },
  {
    "key": "cmd+r right",
    "command": "-views.moveViewRight",
    "when": "focusedView != ''"
  },
  {
    "key": "cmd+r up",
    "command": "-views.moveViewUp",
    "when": "focusedView != ''"
  },
  {
    "key": "cmd+r right",
    "command": "workbench.action.moveEditorToRightGroup"
  },
  {
    "key": "cmd+r left",
    "command": "-workbench.action.moveActiveEditorGroupLeft"
  },
  {
    "key": "cmd+r down",
    "command": "-workbench.action.moveActiveEditorGroupDown"
  },
  {
    "key": "cmd+r up",
    "command": "-workbench.action.moveActiveEditorGroupUp"
  },
  {
    "key": "cmd+r left",
    "command": "workbench.action.moveEditorToLeftGroup"
  },
  {
    "key": "cmd+r up",
    "command": "workbench.action.moveEditorToAboveGroup"
  },
  {
    "key": "cmd+r down",
    "command": "workbench.action.moveEditorToBelowGroup"
  },
  {
    "key": "cmd+n",
    "command": "-composer.createNewChat",
    "when": "focusedView == 'workbench.panel.aichat.view'"
  },
  {
    "key": "cmd+n",
    "command": "-composer.createNew",
    "when": "focusedView == 'workbench.panel.composerViewPane2.view'"
