#!/usr/bin/env bash

set -euo pipefail

rayconfig="${1:-}"
icloud_dir="${HOME}/Library/Mobile Documents/com~apple~CloudDocs"
raycast_dir="${icloud_dir}/Raycast"

if [[ -z "$rayconfig" ]]; then
  if [[ -d "$raycast_dir" ]]; then
    rayconfig="$(find "$raycast_dir" -name '*.rayconfig' -print 2>/dev/null | sort | tail -1 || true)"
  fi

  if [[ -z "$rayconfig" && -d "$icloud_dir" ]]; then
    rayconfig="$(find "$icloud_dir" -name '*.rayconfig' -print 2>/dev/null | sort | tail -1 || true)"
  fi
fi

if [[ -z "$rayconfig" || ! -f "$rayconfig" ]]; then
  printf 'No Raycast .rayconfig export found in iCloud Drive/Raycast. Export Raycast settings there, or pass a path: ./bin/raycast-restore /path/to/export.rayconfig\n' >&2
  exit 1
fi

open -a Raycast 2>/dev/null || true
open "$rayconfig"

printf 'Opened Raycast export: %s\n' "$rayconfig"
printf 'Use Raycast Import Settings & Data and enter the export passphrase when prompted.\n'
