#!/usr/bin/env bash

set -euo pipefail

icloud_drive="${HOME}/Library/Mobile Documents/com~apple~CloudDocs"
default_archive="${icloud_drive}/Codex/codex-state-latest.tar.gz.age"
dry_run=0
archive_path=""
tmp_dir=""
backup_root="${HOME}/.dotfiles-backups/$(date +%Y%m%d-%H%M%S)/codex-state"
created_backup_root=0

usage() {
  cat >&2 <<'EOF'
Usage: ./bin/codex-restore [--dry-run] [ARCHIVE_PATH]

Decrypts and restores a curated Codex state archive created by
./bin/codex-backup. The passphrase is prompted by age and is never stored by
this script.
EOF
}

log() {
  printf '==> %s\n' "$1"
}

warn() {
  printf '!! %s\n' "$1" >&2
}

cleanup() {
  [[ -n "$tmp_dir" && -d "$tmp_dir" ]] && rm -rf "$tmp_dir"
  return 0
}

need_command() {
  local command_name="$1"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    warn "Missing required command: ${command_name}"
    if [[ "$command_name" == "age" ]]; then
      warn "Run ./bin/setup or mise install age, then rerun ./bin/codex-restore."
    fi
    exit 1
  fi
}

normalize_entry() {
  local entry="$1"

  entry="${entry#./}"
  entry="${entry%/}"
  printf '%s\n' "$entry"
}

entry_is_allowed() {
  local entry="$1"

  [[ -z "$entry" || "$entry" == "." ]] && return 0
  [[ "$entry" == "MANIFEST.txt" ]] && return 0
  [[ "$entry" == ".codex" ]] && return 0
  [[ "$entry" == ".agents" ]] && return 0
  [[ "$entry" == ".codex/config.toml" ]] && return 0
  [[ "$entry" == ".codex/keybindings.json" ]] && return 0
  [[ "$entry" == ".codex/AGENTS.md" ]] && return 0
  [[ "$entry" == ".codex/.codex-global-state.json" ]] && return 0
  [[ "$entry" == ".codex/rules" || "$entry" == .codex/rules/* ]] && return 0
  [[ "$entry" == ".codex/memories" || "$entry" == .codex/memories/* ]] && return 0
  [[ "$entry" == ".agents/skills" || "$entry" == .agents/skills/* ]] && return 0

  return 1
}

entry_is_excluded() {
  local entry="$1"

  case "$entry" in
    .codex/auth.json | \
    .codex/history.jsonl | \
    .codex/installation_id | \
    .codex/session_index.jsonl | \
    .codex/attachments | .codex/attachments/* | \
    .codex/browser | .codex/browser/* | \
    .codex/cache | .codex/cache/* | \
    .codex/log | .codex/log/* | \
    .codex/logs | .codex/logs/* | \
    .codex/node_repl | .codex/node_repl/* | \
    .codex/plugins | .codex/plugins/* | \
    .codex/sessions | .codex/sessions/* | \
    .codex/shell_snapshots | .codex/shell_snapshots/* | \
    .codex/sqlite | .codex/sqlite/* | \
    .codex/worktrees | .codex/worktrees/* | \
    .codex/.tmp | .codex/.tmp/* | \
    .codex/tmp | .codex/tmp/* | \
    .codex/app-server-control | .codex/app-server-control/* | \
    .codex/computer-use | .codex/computer-use/* | \
    *.sqlite | *.sqlite-shm | *.sqlite-wal)
      return 0
      ;;
  esac

  return 1
}

validate_entries() {
  local entries_file="$1"
  local raw_entry entry failures=0

  while IFS= read -r raw_entry || [[ -n "$raw_entry" ]]; do
    entry="$(normalize_entry "$raw_entry")"

    if [[ "$entry" == /* || "$entry" == *".."* ]]; then
      warn "Archive contains unsafe path: ${raw_entry}"
      failures=$((failures + 1))
      continue
    fi

    if ! entry_is_allowed "$entry"; then
      warn "Archive contains non-allowlisted path: ${raw_entry}"
      failures=$((failures + 1))
      continue
    fi

    if entry_is_excluded "$entry"; then
      warn "Archive contains excluded path: ${raw_entry}"
      failures=$((failures + 1))
    fi
  done < "$entries_file"

  [[ "$failures" -eq 0 ]]
}

backup_target() {
  local target="$1"
  local relative="$2"
  local backup_path="${backup_root}/${relative}"

  [[ -e "$target" || -L "$target" ]] || return 0

  if [[ "$created_backup_root" -eq 0 ]]; then
    mkdir -p "$backup_root"
    created_backup_root=1
  fi

  mkdir -p "$(dirname "$backup_path")"
  mv "$target" "$backup_path"
  printf 'Backed up %s -> %s\n' "$target" "$backup_path"
}

backup_linked_directory_contents() {
  local target="$1"
  local relative="$2"
  local backup_path="${backup_root}/${relative}"

  [[ -d "$target" ]] || return 0

  if [[ "$created_backup_root" -eq 0 ]]; then
    mkdir -p "$backup_root"
    created_backup_root=1
  fi

  mkdir -p "$backup_path"
  (cd "$target" && tar -cf - .) | (cd "$backup_path" && tar -xf -)
  printf 'Backed up %s contents -> %s\n' "$target" "$backup_path"
}

copy_directory_contents() {
  local source="$1"
  local target="$2"

  mkdir -p "$target"
  (cd "$source" && tar -cf - .) | (cd "$target" && tar -xf -)
}

restore_path() {
  local relative="$1"
  local source="${tmp_dir}/payload/${relative}"
  local target="${HOME}/${relative}"

  [[ -e "$source" || -L "$source" ]] || return 0

  if [[ -d "$source" ]]; then
    if [[ "$relative" == ".agents/skills" && -L "$target" && -d "$target" ]]; then
      backup_linked_directory_contents "$target" "$relative"
      copy_directory_contents "$source" "$target"
      printf 'Merged %s -> %s\n' "$source" "$target"
      return 0
    fi

    backup_target "$target" "$relative"
    mkdir -p "$(dirname "$target")"
    copy_directory_contents "$source" "$target"
    printf 'Restored %s -> %s\n' "$source" "$target"
  else
    backup_target "$target" "$relative"
    mkdir -p "$(dirname "$target")"
    cp -p "$source" "$target"
    printf 'Restored %s -> %s\n' "$source" "$target"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    -*)
      usage
      exit 1
      ;;
    *)
      if [[ -n "$archive_path" ]]; then
        usage
        exit 1
      fi
      archive_path="$1"
      shift
      ;;
  esac
done

archive_path="${archive_path:-$default_archive}"

trap cleanup EXIT

need_command age
need_command tar

if [[ ! -f "$archive_path" ]]; then
  warn "Codex state archive not found: ${archive_path}"
  warn "On the old Mac, run ./bin/codex-backup and wait for iCloud sync."
  exit 1
fi

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/codex-state-restore.XXXXXX")"

log "Decrypting ${archive_path}"
age -d -o "${tmp_dir}/payload.tar.gz" "$archive_path"

tar -tzf "${tmp_dir}/payload.tar.gz" > "${tmp_dir}/entries.txt"

if ! validate_entries "${tmp_dir}/entries.txt"; then
  warn "Archive failed allowlist validation; refusing to restore."
  exit 1
fi

mkdir -p "${tmp_dir}/payload"
tar -xzf "${tmp_dir}/payload.tar.gz" -C "${tmp_dir}/payload"

log "Archive manifest"
if [[ -f "${tmp_dir}/payload/MANIFEST.txt" ]]; then
  sed 's/^/  /' "${tmp_dir}/payload/MANIFEST.txt"
else
  warn "Archive has no MANIFEST.txt; validated entries are still allowlisted."
fi

if [[ "$dry_run" -eq 1 ]]; then
  log "Dry run complete; no files restored."
  exit 0
fi

restore_path ".codex/config.toml"
restore_path ".codex/keybindings.json"
restore_path ".codex/AGENTS.md"
restore_path ".codex/.codex-global-state.json"
restore_path ".codex/rules"
restore_path ".codex/memories"
restore_path ".agents/skills"

cat <<EOF

Codex state restore complete.
Replaced targets were backed up under:
  ${backup_root}
EOF
