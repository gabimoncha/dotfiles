#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
timestamp="$(date +%Y%m%d-%H%M%S)"
backup_root="${HOME}/.dotfiles-backups/${timestamp}"
created_backup_root=0

# shellcheck source=bin/lib/setup-runtime.sh
. "${repo_root}/bin/lib/setup-runtime.sh"
runtime_init "link-dotfiles"

cleanup() {
  runtime_cleanup
}

trap cleanup EXIT
runtime_acquire_lock "link-dotfiles" "dotfile linking" || exit 1

managed_sources=(
  "${repo_root}/home/.zshenv"
  "${repo_root}/home/.zprofile"
  "${repo_root}/home/.zshrc"
  "${repo_root}/home/.p10k.zsh"
  "${repo_root}/home/.mackup.cfg"
  "${repo_root}/home/.gitconfig"
  "${repo_root}/home/.rgrc"
  "${repo_root}/home/.tmux.conf"
  "${repo_root}/home/.cli-proxy-api/config.yaml"
  "${repo_root}/home/.config/mise/config.toml"
  "${repo_root}/home/.config/zsh/env.zsh"
  "${repo_root}/home/.config/zsh/profile.zsh"
  "${repo_root}/home/.config/zsh/interactive.zsh"
  "${repo_root}/home/.config/zsh/path.zsh"
  "${repo_root}/home/.config/zsh/aliases.zsh"
  "${repo_root}/home/.config/zsh/mise-npx.zsh"
  "${repo_root}/home/.config/zsh/functions.zsh"
  "${repo_root}/home/.config/zsh/check-updates.zsh"
  "${repo_root}/home/.config/karabiner/karabiner.json"
  "${repo_root}/home/.config/mackup/applications/macs-fan-control.cfg"
  "${repo_root}/home/.config/zed/settings.json"
  "${repo_root}/home/.config/zed/keymap.json"
  "${repo_root}/home/.agents/.skill-lock.json"
  "${repo_root}/home/.agents/skills"
  "${repo_root}/home/Documents/superwhisper/settings/settings.json"
  "${repo_root}/home/scripts/toggle_function_keys.sh"
)

managed_app_sources=(
  "AeroSpace|${repo_root}/home/.aerospace.toml"
  "Ghostty|${repo_root}/home/Library/Application Support/com.mitchellh.ghostty/config"
)

if [[ -d "${repo_root}/nvim" ]] && find "${repo_root}/nvim" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
  managed_sources+=("${repo_root}/nvim")
else
  printf 'Skipping nvim link; submodule is not initialized\n'
fi

backup_target() {
  local target="$1"
  local relative_target backup_path

  [[ ${created_backup_root} -eq 1 ]] || {
    mkdir -p "${backup_root}"
    created_backup_root=1
  }

  if [[ "${target}" == "${HOME}/"* ]]; then
    relative_target="${target#${HOME}/}"
  else
    relative_target="root/${target#/}"
  fi
  backup_path="${backup_root}/${relative_target}"
  mkdir -p "$(dirname "${backup_path}")"
  mv "${target}" "${backup_path}"
  printf 'Backed up %s -> %s\n' "${target}" "${backup_path}"
}

link_cliproxyapi_homebrew_config() {
  local home_config="${HOME}/.cli-proxy-api/config.yaml"
  local brew_prefix brew_config

  if ! command -v brew >/dev/null 2>&1; then
    printf 'Skipping CLIProxyAPI Homebrew config link; Homebrew is not installed\n'
    return 0
  fi

  brew_prefix="$(brew --prefix)"
  brew_config="${brew_prefix}/etc/cliproxyapi.conf"

  if [[ ! -e "${home_config}" ]]; then
    printf 'Skipping CLIProxyAPI Homebrew config link; %s is missing\n' "${home_config}"
    return 0
  fi

  if [[ -L "${brew_config}" && "$(readlink "${brew_config}")" == "${home_config}" ]]; then
    printf 'Already linked %s\n' "${brew_config}"
    return 0
  fi

  mkdir -p "$(dirname "${brew_config}")"
  if [[ -e "${brew_config}" || -L "${brew_config}" ]]; then
    backup_target "${brew_config}"
  fi

  ln -s "${home_config}" "${brew_config}"
  printf 'Linked %s -> %s\n' "${brew_config}" "${home_config}"
}

preserve_git_identity() {
  local target="$1"
  local local_config="${HOME}/.gitconfig.local"
  local name email

  [[ "$target" == "${HOME}/.gitconfig" ]] || return 0
  [[ -e "$target" || -L "$target" ]] || return 0

  name="$(git config --file "$target" --get user.name 2>/dev/null || true)"
  email="$(git config --file "$target" --get user.email 2>/dev/null || true)"

  if [[ -n "$name" && -z "$(git config --file "$local_config" --get user.name 2>/dev/null || true)" ]]; then
    git config --file "$local_config" user.name "$name"
    chmod 600 "$local_config"
    printf 'Preserved Git user.name in %s\n' "$local_config"
  fi

  if [[ -n "$email" && -z "$(git config --file "$local_config" --get user.email 2>/dev/null || true)" ]]; then
    git config --file "$local_config" user.email "$email"
    chmod 600 "$local_config"
    printf 'Preserved Git user.email in %s\n' "$local_config"
  fi
}

link_path() {
  local source="$1"
  local target="${HOME}/${source#${repo_root}/home/}"

  if [[ "${source}" == "${repo_root}/nvim" ]]; then
    target="${HOME}/.config/nvim"
  fi

  mkdir -p "$(dirname "${target}")"

  if [[ -L "${target}" && "$(readlink "${target}")" == "${source}" ]]; then
    printf 'Already linked %s\n' "${target}"
    return 0
  fi

  if [[ -e "${target}" || -L "${target}" ]]; then
    preserve_git_identity "${target}"
    backup_target "${target}"
  fi

  ln -s "${source}" "${target}"
  printf 'Linked %s -> %s\n' "${target}" "${source}"
}

append_installed_app_sources() {
  local entry app_bundle source

  for entry in "${managed_app_sources[@]}"; do
    app_bundle="${entry%%|*}"
    source="${entry#*|}"

    if [[ -d "/Applications/${app_bundle}.app" ]]; then
      managed_sources+=("${source}")
    else
      printf 'Skipping %s config link; /Applications/%s.app is not installed\n' "${app_bundle}" "${app_bundle}"
    fi
  done
}

append_installed_app_sources

for source in "${managed_sources[@]}"; do
  if [[ ! -e "${source}" && ! -L "${source}" ]]; then
    printf 'Skipping missing source %s\n' "${source}"
    continue
  fi

  link_path "${source}"
done

link_cliproxyapi_homebrew_config
