#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
icloud_dir="${HOME}/Library/Mobile Documents/com~apple~CloudDocs"
synology_dir="${HOME}/Library/CloudStorage/SynologyDrive-personal"
issues=0

ok() {
  printf 'ok   %s\n' "$1"
}

warn() {
  printf 'warn %s\n' "$1"
  issues=$((issues + 1))
}

info() {
  printf 'info %s\n' "$1"
}

newest_file() {
  local dir="$1"
  local pattern="$2"

  [[ -d "$dir" ]] || return 0

  find "$dir" -type f -name "$pattern" -exec stat -f '%m %N' {} \; 2>/dev/null | sort -nr | sed 's/^[0-9][0-9]* //g' | head -1
}

latest_rayconfig() {
  local rayconfig

  if [[ -d "${synology_dir}/MacBackups/Raycast" ]]; then
    rayconfig="$(newest_file "${synology_dir}/MacBackups/Raycast" '*.rayconfig')"
    if [[ -n "$rayconfig" ]]; then
      printf '%s\n' "$rayconfig"
      return 0
    fi
  fi

  if [[ -d "${icloud_dir}/Raycast" ]]; then
    rayconfig="$(newest_file "${icloud_dir}/Raycast" '*.rayconfig')"
    if [[ -n "$rayconfig" ]]; then
      printf '%s\n' "$rayconfig"
      return 0
    fi
  fi

  if [[ -d "$icloud_dir" ]]; then
    newest_file "$icloud_dir" '*.rayconfig'
  fi
}

spotlight_hotkey_enabled() {
  local key="$1"
  local plist="${HOME}/Library/Preferences/com.apple.symbolichotkeys.plist"
  local enabled

  enabled="$(/usr/libexec/PlistBuddy -c "Print :AppleSymbolicHotKeys:${key}:enabled" "$plist" 2>/dev/null || true)"
  [[ -z "$enabled" || "$enabled" == "true" || "$enabled" == "1" ]]
}

check_ghostty() {
  local source="${repo_root}/home/Library/Application Support/com.mitchellh.ghostty/config"
  local target="${HOME}/Library/Application Support/com.mitchellh.ghostty/config"

  if [[ -L "$target" && "$(readlink "$target")" == "$source" ]]; then
    ok "Ghostty config is linked at ~/Library/Application Support/com.mitchellh.ghostty/config"
    return 0
  fi

  if [[ -e "$target" || -L "$target" ]]; then
    warn "Ghostty config exists but is not linked to this repo"
  else
    warn "Ghostty config is missing at ~/Library/Application Support/com.mitchellh.ghostty/config"
  fi
  info "Run ./bin/link-dotfiles after Ghostty is installed."
}

check_aerospace() {
  local source="${repo_root}/home/.aerospace.toml"
  local target="${HOME}/.aerospace.toml"

  if [[ -L "$target" && "$(readlink "$target")" == "$source" ]]; then
    ok "AeroSpace config is linked at ~/.aerospace.toml"
    return 0
  fi

  if [[ -e "$target" || -L "$target" ]]; then
    warn "AeroSpace config exists but is not linked to this repo"
  else
    warn "AeroSpace config is missing at ~/.aerospace.toml"
  fi
  info "Run ./bin/link-dotfiles after AeroSpace is installed."
}

check_tmux() {
  local missing=()
  local plugin
  local plugin_name

  if [[ -f "${HOME}/.tmux.conf" || -L "${HOME}/.tmux.conf" ]]; then
    ok "tmux config exists at ~/.tmux.conf"
  else
    warn "tmux config is missing; run ./bin/link-dotfiles"
  fi

  while IFS= read -r plugin || [[ -n "$plugin" ]]; do
    [[ -z "$plugin" || "$plugin" == "tmux-plugins/tpm" ]] && continue
    plugin_name="${plugin##*/}"
    plugin_name="${plugin_name%%#*}"
    if [[ ! -d "${HOME}/.tmux/plugins/${plugin_name}" ]]; then
      missing+=("$plugin_name")
    fi
  done < <(sed -n "s/^[[:space:]]*set -g @plugin ['\"]\\([^'\"]*\\)['\"].*/\\1/p" "${repo_root}/home/.tmux.conf")

  if [[ ${#missing[@]} -eq 0 ]]; then
    ok "tmux plugins are installed"
  else
    warn "tmux plugins missing: ${missing[*]}"
    info "Run ./bin/setup-tmux to install missing TPM plugins."
  fi
}

check_raycast() {
  local rayconfig

  if [[ -d "/Applications/Raycast.app" ]]; then
    ok "Raycast.app is installed"
  else
    warn "Raycast.app is missing; run ./bin/setup or ./bin/install-apps"
  fi

  if spotlight_hotkey_enabled 64 || spotlight_hotkey_enabled 65; then
    warn "Spotlight Command-Space hotkeys are enabled"
    info "Run ./macos/defaults.sh, then log out and back in if Spotlight still captures Command-Space."
  else
    ok "Spotlight Command-Space hotkeys are disabled"
  fi

  rayconfig="$(latest_rayconfig || true)"
  if [[ -n "$rayconfig" && -f "$rayconfig" ]]; then
    ok "Raycast export found: ${rayconfig}"
  else
    warn "No Raycast .rayconfig export found in Synology Drive or iCloud Drive"
    info "On the old Mac, run ./bin/file-backup raycast and use Raycast's Export Settings & Data flow."
  fi
}

check_sudo_touch_id() {
  if [[ "$(uname)" != "Darwin" ]]; then
    return 0
  fi

  if [[ ! -f /etc/pam.d/sudo ]]; then
    warn "sudo PAM config is missing at /etc/pam.d/sudo"
    return 0
  fi

  if ! awk '$1 == "auth" && $2 == "include" && $3 == "sudo_local" { found = 1 } END { exit found ? 0 : 1 }' /etc/pam.d/sudo; then
    warn "sudo PAM config does not include sudo_local"
    info "This repo will not edit Apple's managed /etc/pam.d/sudo file."
    return 0
  fi

  if [[ -f /etc/pam.d/sudo_local ]] && awk '$1 == "auth" && $2 == "sufficient" && $3 == "pam_tid.so" { found = 1 } END { exit found ? 0 : 1 }' /etc/pam.d/sudo_local; then
    ok "Touch ID for sudo is enabled"
  else
    warn "Touch ID for sudo is not enabled"
    info "Run ./bin/configure-sudo-touch-id --enable."
  fi

  info "Apple Watch approval depends on macOS Auto Unlock settings and is not directly managed by this repo."
}

check_aerospace
check_ghostty
check_tmux
check_raycast
check_sudo_touch_id

if [[ $issues -gt 0 ]]; then
  printf '\nFound %s app-state issue(s).\n' "$issues"
  exit 1
fi

printf '\nApp state looks ready.\n'
