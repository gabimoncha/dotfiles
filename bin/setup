#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
manifest="${repo_root}/apps/manifest.tsv"
dry_run=0
setup_status=0
skip_mobile_dev="${DOTFILES_SKIP_MOBILE_DEV:-0}"
homebrew_no_require_tap_trust_was_set=0
homebrew_no_require_tap_trust_original=""

# shellcheck source=bin/lib/setup-runtime.sh
. "${repo_root}/bin/lib/setup-runtime.sh"
runtime_init "setup"

cleanup() {
  runtime_cleanup
  restore_homebrew_tap_trust_setting
}

log() {
  printf '==> %s\n' "$1"
}

warn() {
  printf '!! %s\n' "$1" >&2
}

usage() {
  printf 'Usage: ./bin/setup [--dry-run] [--skip-mobile-dev] [--serial]\n' >&2
}

enable_temporary_homebrew_tap_trust_bypass() {
  if [[ ${HOMEBREW_NO_REQUIRE_TAP_TRUST+x} ]]; then
    homebrew_no_require_tap_trust_was_set=1
    homebrew_no_require_tap_trust_original="$HOMEBREW_NO_REQUIRE_TAP_TRUST"
  fi

  export HOMEBREW_NO_REQUIRE_TAP_TRUST=1
}

restore_homebrew_tap_trust_setting() {
  if [[ "$homebrew_no_require_tap_trust_was_set" -eq 1 ]]; then
    export HOMEBREW_NO_REQUIRE_TAP_TRUST="$homebrew_no_require_tap_trust_original"
  else
    unset HOMEBREW_NO_REQUIRE_TAP_TRUST
  fi
}

ensure_not_root() {
  if [[ "${EUID}" -eq 0 ]]; then
    warn "Do not run ./bin/setup with sudo or as root."
    warn "Run: ./bin/setup"
    warn "The scripts will ask for sudo only when a specific privileged step needs it."
    exit 1
  fi
}

load_homebrew_shellenv() {
  if [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/brew" ]]; then
    eval "$("${HOMEBREW_PREFIX}/bin/brew" shellenv)"
    return 0
  fi

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  elif command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
  fi
}

app_installed() {
  local app_bundle="$1"
  [[ -n "$app_bundle" && "$app_bundle" != "-" && -d "/Applications/${app_bundle}.app" ]]
}

latest_rayconfig() {
  local icloud_dir="${HOME}/Library/Mobile Documents/com~apple~CloudDocs"
  local raycast_dir="${icloud_dir}/Raycast"
  local rayconfig

  if [[ -d "$raycast_dir" ]]; then
    rayconfig="$(find "$raycast_dir" -name '*.rayconfig' -print 2>/dev/null | sort | tail -1 || true)"
    if [[ -n "$rayconfig" ]]; then
      printf '%s\n' "$rayconfig"
      return 0
    fi
  fi

  if [[ -d "$icloud_dir" ]]; then
    find "$icloud_dir" -name '*.rayconfig' -print 2>/dev/null | sort | tail -1 || true
  fi
}

print_manifest_summary() {
  local key type token_or_url app_bundle notes
  local installed_count=0 skipped_count=0 deferred_count=0 manual_count=0
  local manual_items=()

  if [[ ! -f "$manifest" ]]; then
    warn "Missing app manifest: ${manifest}"
    return 0
  fi

  load_homebrew_shellenv

  while IFS=$'\t' read -r key type token_or_url app_bundle notes || [[ -n "${key:-}" ]]; do
    [[ -z "${key:-}" || "$key" == \#* ]] && continue

    case "$type" in
      cask)
        if app_installed "$app_bundle"; then
          skipped_count=$((skipped_count + 1))
        elif command -v brew >/dev/null 2>&1 && brew list --cask "$token_or_url" >/dev/null 2>&1; then
          installed_count=$((installed_count + 1))
        else
          deferred_count=$((deferred_count + 1))
        fi
        ;;
      formula)
        if command -v brew >/dev/null 2>&1 && brew list --formula "$token_or_url" >/dev/null 2>&1; then
          installed_count=$((installed_count + 1))
        else
          deferred_count=$((deferred_count + 1))
        fi
        ;;
      mise)
        if command -v mise >/dev/null 2>&1; then
          installed_count=$((installed_count + 1))
        else
          deferred_count=$((deferred_count + 1))
        fi
        ;;
      manual)
        if app_installed "$app_bundle"; then
          skipped_count=$((skipped_count + 1))
        else
          manual_count=$((manual_count + 1))
          manual_items+=("$key")
        fi
        ;;
      *)
        deferred_count=$((deferred_count + 1))
        ;;
    esac
  done < "$manifest"

  cat <<EOF

Setup summary:
- installed/managed: ${installed_count}
- skipped/already present: ${skipped_count}
- deferred until prerequisites are ready: ${deferred_count}
- manual/vendor apps: ${manual_count}
EOF

  if [[ ${#manual_items[@]} -gt 0 ]]; then
    printf 'Manual app keys: %s\n' "${manual_items[*]}"
  fi
}

print_shell_reload_hint() {
  cat <<'EOF'

Shell environment updated.
Open a new terminal, or reload this one with:
  source "$HOME/.zshrc"
EOF
}

run_interactive_followup() {
  local rayconfig

  cat <<'EOF'

Press Enter to continue interactive auth/restore steps, or rerun `./bin/setup` later.
EOF

  if [[ ! -t 0 ]]; then
    warn "Non-interactive shell; skipping auth and restore follow-up"
    runtime_record_deferred "Interactive follow-up" "non-interactive shell" "Rerun ./bin/setup in a terminal, or run ./bin/auth-setup and ./bin/mackup-restore manually."
    return 0
  fi

  read -r _

  if "${repo_root}/bin/auth-setup"; then
    runtime_record_completed "Auth setup"
  else
    runtime_record_failure recoverable "Auth setup" "auth setup failed" "" "Rerun ./bin/auth-setup."
  fi

  if "${repo_root}/bin/mackup-restore"; then
    runtime_record_completed "Mackup restore"
  else
    runtime_record_failure recoverable "Mackup restore" "Mackup restore failed" "" "Rerun ./bin/mackup-restore after iCloud Drive is ready."
  fi

  rayconfig="$(latest_rayconfig)"
  if [[ -n "$rayconfig" && -f "$rayconfig" ]]; then
    if "${repo_root}/bin/raycast-restore" "$rayconfig"; then
      runtime_record_completed "Raycast restore"
    else
      runtime_record_failure recoverable "Raycast restore" "Raycast restore failed" "" "Rerun ./bin/raycast-restore after checking the export passphrase."
    fi
  else
    log "Raycast restore deferred"
    runtime_record_deferred "Raycast restore" "no .rayconfig export was found in iCloud Drive/Raycast" "Run ./bin/raycast-backup on the old Mac, wait for iCloud sync, then rerun ./bin/setup."
    cat <<'EOF'
No Raycast .rayconfig export was found in iCloud Drive/Raycast.

On the old Mac, run ./bin/raycast-backup and export Raycast settings to iCloud Drive/Raycast.
On this Mac, rerun ./bin/setup or ./bin/raycast-restore after iCloud syncs the export.

This is expected until the encrypted Raycast export exists. Do not commit .rayconfig files or their passphrases.
EOF
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    --skip-mobile-dev)
      skip_mobile_dev=1
      shift
      ;;
    --serial)
      DOTFILES_SETUP_SERIAL=1
      export DOTFILES_SETUP_SERIAL
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 1
      ;;
  esac
done

if [[ "$dry_run" -eq 1 ]]; then
  DOTFILES_SETUP_SERIAL=1
  export DOTFILES_SETUP_SERIAL
fi

export DOTFILES_SKIP_MOBILE_DEV="$skip_mobile_dev"

enable_temporary_homebrew_tap_trust_bypass
trap cleanup EXIT

ensure_not_root
if ! runtime_acquire_global_lock; then
  runtime_print_summary
  exit 1
fi

log "Running preflight"
if "${repo_root}/bin/preflight"; then
  runtime_record_completed "Preflight"
else
  runtime_record_failure critical "Preflight" "preflight failed" "" "Fix the failed preflight checks, then rerun ./bin/setup."
  runtime_print_summary
  exit 1
fi

if [[ $dry_run -eq 1 ]]; then
  log "dry-run: would run ./bin/bootstrap"
  if [[ "$skip_mobile_dev" -eq 1 ]]; then
    runtime_record_deferred "Mobile dev stack" "dry-run skipped because --skip-mobile-dev was set" "Rerun ./bin/setup without --skip-mobile-dev to install mobile dev tools."
  else
    "${repo_root}/bin/install-mobile-dev" --dry-run || setup_status=1
  fi
  if "${repo_root}/bin/install-apps" --dry-run; then
    runtime_record_completed "Manifest app dry-run"
  else
    runtime_record_failure recoverable "Manifest app dry-run" "install-apps dry-run failed" "" "Rerun ./bin/install-apps --dry-run after fixing the logged error."
    setup_status=1
  fi
  print_manifest_summary
  runtime_print_summary
  if [[ "$setup_status" -ne 0 ]]; then
    exit "$setup_status"
  fi
  runtime_exit_status
  exit $?
fi

log "Running bootstrap"
if "${repo_root}/bin/bootstrap"; then
  runtime_record_completed "Bootstrap"
else
  runtime_record_failure recoverable "Bootstrap" "bootstrap completed with issues" "" "Review the failures above, then rerun ./bin/setup."
  setup_status=1
fi

if ! xcode-select -p >/dev/null 2>&1; then
  warn "Xcode Command Line Tools are not ready yet; skipping the remaining setup steps"
  warn "Finish the installer popup, then rerun: ./bin/setup"
  runtime_record_failure critical "Xcode Command Line Tools" "installer handoff is not complete" "" "Finish the installer popup, then rerun ./bin/setup."
  runtime_print_summary
  exit 1
fi

log "Installing extra apps from manifest"
if "${repo_root}/bin/install-apps"; then
  runtime_record_completed "Manifest app install pass"
else
  runtime_record_failure recoverable "Manifest app install pass" "install-apps failed" "" "Rerun ./bin/install-apps after fixing the logged error."
  setup_status=1
fi

log "Linking app dotfiles"
if "${repo_root}/bin/link-dotfiles"; then
  runtime_record_completed "Final app dotfile links"
else
  runtime_record_failure recoverable "Final app dotfile links" "link-dotfiles failed" "" "Rerun ./bin/link-dotfiles."
  setup_status=1
fi

print_manifest_summary
run_interactive_followup
print_shell_reload_hint
runtime_print_summary

if [[ "$setup_status" -ne 0 ]]; then
  exit "$setup_status"
fi
runtime_exit_status
