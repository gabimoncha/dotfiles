#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

log() {
  printf '==> %s\n' "$1"
}

warn() {
  printf '!! %s\n' "$1" >&2
}

load_homebrew_shellenv() {
  if [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/brew" ]]; then
    eval "$("${HOMEBREW_PREFIX}/bin/brew" shellenv)"
    return 0
  fi

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  elif command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
  fi
}

run_gh() {
  if command -v gh >/dev/null 2>&1; then
    gh "$@"
    return $?
  fi

  if command -v mise >/dev/null 2>&1; then
    (cd "$repo_root" && mise exec -- gh "$@")
    return $?
  fi

  return 127
}

gh_available() {
  run_gh --version >/dev/null 2>&1
}

default_git_email() {
  git config --global --includes user.email 2>/dev/null || true
}

default_git_name() {
  git config --global --includes user.name 2>/dev/null || true
}

default_key_comment() {
  local host

  host="$(scutil --get ComputerName 2>/dev/null || hostname -s 2>/dev/null || hostname)"
  printf '%s@%s\n' "$(whoami)" "$host"
}

ensure_git_identity() {
  local local_config="${HOME}/.gitconfig.local"
  local name email default_name default_email

  if git -c user.useConfigOnly=true var GIT_AUTHOR_IDENT >/dev/null 2>&1; then
    log "Git identity is configured"
    return 0
  fi

  if [[ ! -t 0 ]]; then
    warn "Git identity is missing; create ~/.gitconfig.local or rerun ./bin/auth-setup interactively."
    return 0
  fi

  default_name="$(default_git_name)"
  if [[ -z "$default_name" ]]; then
    default_name="$(whoami)"
  fi

  default_email="$(default_git_email)"

  log "Configuring Git identity in ${local_config}"

  read -r -p "Git user.name [${default_name}]: " name
  name="${name:-$default_name}"

  while [[ -z "${email:-}" ]]; do
    if [[ -n "$default_email" ]]; then
      read -r -p "Git user.email [${default_email}]: " email
      email="${email:-$default_email}"
    else
      read -r -p "Git user.email: " email
    fi
  done

  git config --file "$local_config" user.name "$name"
  git config --file "$local_config" user.email "$email"
  chmod 600 "$local_config"
}

ensure_ssh_key() {
  local key_path="${HOME}/.ssh/id_ed25519"
  local email

  mkdir -p "${HOME}/.ssh"
  chmod 700 "${HOME}/.ssh"

  if [[ -f "$key_path" && ! -f "${key_path}.pub" ]]; then
    log "Rebuilding SSH public key: ${key_path}.pub"
    ssh-keygen -y -f "$key_path" > "${key_path}.pub"
  fi

  if [[ -f "$key_path" && -f "${key_path}.pub" ]]; then
    log "SSH key exists: ${key_path}"
    return 0
  fi

  email="$(default_git_email)"
  if [[ -z "$email" ]]; then
    email="$(default_key_comment)"
  fi

  log "Generating SSH key: ${key_path}"
  ssh-keygen -t ed25519 -C "$email" -f "$key_path" -N ""
}

add_ssh_key_to_agent() {
  local key_path="${HOME}/.ssh/id_ed25519"

  if [[ ! -f "$key_path" ]]; then
    warn "No SSH private key found to add to the agent"
    return 0
  fi

  log "Adding SSH key to macOS keychain-backed agent"
  ssh-add --apple-use-keychain "$key_path" 2>/dev/null || ssh-add "$key_path" || true
}

ensure_github_known_host() {
  local known_hosts="${HOME}/.ssh/known_hosts"

  mkdir -p "${HOME}/.ssh"
  chmod 700 "${HOME}/.ssh"
  touch "$known_hosts"
  chmod 600 "$known_hosts"

  if ssh-keygen -F github.com -f "$known_hosts" >/dev/null 2>&1; then
    return 0
  fi

  log "Adding github.com to SSH known_hosts"
  ssh-keyscan github.com >> "$known_hosts" 2>/dev/null || {
    warn "Could not add github.com to SSH known_hosts"
  }
}

configure_gh_git_protocol() {
  run_gh config set git_protocol ssh --host github.com >/dev/null 2>&1 || {
    warn "Could not set gh git_protocol=ssh"
  }
}

github_ssh_authenticated() {
  local output

  set +e
  output="$(ssh -o BatchMode=yes -o ConnectTimeout=5 -T git@github.com 2>&1)"
  set -e

  [[ "$output" == *"successfully authenticated"* ]]
}

configure_dotfiles_origin_remote() {
  local current_url
  local ssh_url="git@github.com:gabimoncha/dotfiles.git"

  if ! git -C "$repo_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  current_url="$(git -C "$repo_root" remote get-url origin 2>/dev/null || true)"

  case "$current_url" in
    "$ssh_url")
      log "dotfiles origin already uses SSH"
      ;;
    https://github.com/gabimoncha/dotfiles | https://github.com/gabimoncha/dotfiles.git)
      if github_ssh_authenticated; then
        log "Switching dotfiles origin to SSH"
        git -C "$repo_root" remote set-url origin "$ssh_url"
      else
        warn "dotfiles origin still uses HTTPS; rerun ./bin/auth-setup after GitHub SSH works"
      fi
      ;;
  esac
}

github_public_key_scope_error() {
  local output="$1"

  [[ "$output" == *"admin:public_key"* || "$output" == *"public_key"* || "$output" == *"HTTP 404"* ]]
}

ensure_github_public_key_scope() {
  if [[ ! -t 0 ]]; then
    warn "GitHub CLI needs the admin:public_key scope to upload SSH keys."
    warn "Rerun ./bin/auth-setup interactively, or run: gh auth refresh -h github.com -s admin:public_key"
    return 1
  fi

  log "Refreshing GitHub CLI public-key scope"
  run_gh auth refresh --hostname github.com --scopes admin:public_key || {
    warn "Could not refresh GitHub CLI public-key scope"
    return 1
  }
}

ensure_github_auth() {
  if ! gh_available; then
    warn "gh is not available through PATH or mise. Run ./bin/setup, or run: cd ${repo_root} && mise install gh"
    return 0
  fi

  if run_gh auth status --hostname github.com >/dev/null 2>&1; then
    log "GitHub CLI is authenticated"
    configure_gh_git_protocol
    return 0
  fi

  if [[ ! -t 0 ]]; then
    warn "GitHub CLI authentication requires an interactive terminal; rerun ./bin/auth-setup"
    return 0
  fi

  log "Authenticating GitHub CLI with SSH git protocol"
  run_gh auth login --hostname github.com --git-protocol ssh --skip-ssh-key
  configure_gh_git_protocol
}

upload_ssh_key_to_github() {
  local key_path="${HOME}/.ssh/id_ed25519.pub"
  local key_contents keys title output status

  if [[ ! -f "$key_path" ]]; then
    warn "No SSH public key found to upload"
    return 0
  fi

  if ! gh_available || ! run_gh auth status --hostname github.com >/dev/null 2>&1; then
    warn "GitHub CLI is not authenticated; cannot upload SSH key"
    return 0
  fi

  key_contents="$(awk '{ print $1 " " $2 }' "$key_path")"
  set +e
  keys="$(run_gh api user/keys --jq '.[].key' 2>&1)"
  status=$?
  set -e

  if [[ $status -ne 0 ]]; then
    if github_public_key_scope_error "$keys"; then
      ensure_github_public_key_scope || return 0
      set +e
      keys="$(run_gh api user/keys --jq '.[].key' 2>&1)"
      status=$?
      set -e
    fi

    if [[ $status -ne 0 ]]; then
      warn "Could not list GitHub SSH keys: ${keys}"
      return 0
    fi
  fi

  if printf '%s\n' "$keys" | grep -Fxq "$key_contents"; then
    log "SSH key already exists on GitHub"
    return 0
  fi

  title="$(scutil --get ComputerName 2>/dev/null || hostname)"
  output="$(run_gh ssh-key add "$key_path" --title "$title" 2>&1)" || {
    if github_public_key_scope_error "$output"; then
      ensure_github_public_key_scope || return 0
      output="$(run_gh ssh-key add "$key_path" --title "$title" 2>&1)" || {
        warn "Could not upload SSH key to GitHub: ${output}"
        return 0
      }
    else
      warn "Could not upload SSH key to GitHub: ${output}"
      return 0
    fi
  }

  if [[ "$output" == *"already exists"* ]]; then
    log "SSH key already exists on GitHub"
    return 0
  fi

  [[ -z "$output" ]] || printf '%s\n' "$output"
  log "Uploaded SSH key to GitHub"
}

verify_github_ssh() {
  local output

  set +e
  output="$(ssh -o BatchMode=yes -o ConnectTimeout=5 -T git@github.com 2>&1)"
  set -e

  if [[ "$output" == *"successfully authenticated"* ]]; then
    log "GitHub SSH works"
  else
    warn "GitHub SSH is not verified yet: ${output}"
  fi
}

print_manual_followup() {
  cat <<'EOF'

Manual account and permission steps:
- Sign in to Apple ID, App Store, and iCloud.
- Sign in to Cursor, VS Code Settings Sync if desired, Notion, Synology Drive, superwhisper, and DaVinci Resolve.
- Grant Accessibility / Automation / Microphone / network permissions when macOS prompts.
- Run `gh auth status` and `ssh -T git@github.com` if GitHub access still looks wrong.
EOF
}

load_homebrew_shellenv
ensure_git_identity
ensure_ssh_key
add_ssh_key_to_agent
ensure_github_known_host
ensure_github_auth
upload_ssh_key_to_github
verify_github_ssh
configure_dotfiles_origin_remote
print_manual_followup
