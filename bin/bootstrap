#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
macos_defaults_flag="${HOME}/.macos-defaults-applied"
temp_brewfile=""
xcode_brewfile=""
mas_brewfile=""
vscode_brewfile=""
sudo_keepalive_pid=""
bootstrap_status=0
mas_checked=0
mas_available=0
homebrew_xcode_checked=0
homebrew_xcode_too_old=0
mise_bin_dir="${HOME}/.local/bin"
mise_shim_dir="${HOME}/.local/share/mise/shims"
brew_bundle_jobs="${DOTFILES_BREW_BUNDLE_JOBS:-auto}"
mobile_dev_enabled=1

# shellcheck source=bin/lib/setup-runtime.sh
. "${repo_root}/bin/lib/setup-runtime.sh"
runtime_init "bootstrap"

if [[ "${DOTFILES_SKIP_MOBILE_DEV:-0}" == "1" ]]; then
  mobile_dev_enabled=0
fi

cleanup() {
  runtime_cleanup

  if [[ -n "$temp_brewfile" ]]; then
    rm -f "$temp_brewfile"
  fi

  if [[ -n "$xcode_brewfile" ]]; then
    rm -f "$xcode_brewfile"
  fi

  if [[ -n "$mas_brewfile" ]]; then
    rm -f "$mas_brewfile"
  fi

  if [[ -n "$vscode_brewfile" ]]; then
    rm -f "$vscode_brewfile"
  fi

  if [[ -n "$sudo_keepalive_pid" ]]; then
    kill "$sudo_keepalive_pid" 2>/dev/null || true
    wait "$sudo_keepalive_pid" 2>/dev/null || true
  fi
}

trap cleanup EXIT

log() {
  printf '==> %s\n' "$1"
}

warn() {
  printf '!! %s\n' "$1" >&2
}

prepend_mise_shims() {
  local path_entry
  local new_path="${mise_bin_dir}:${mise_shim_dir}"
  local path_entries=()

  IFS=':' read -r -a path_entries <<< "$PATH"
  for path_entry in "${path_entries[@]}"; do
    [[ -z "$path_entry" ]] && continue
    case "$path_entry" in
      "$mise_bin_dir" | "$mise_shim_dir") continue ;;
    esac
    new_path="${new_path}:${path_entry}"
  done

  export PATH="$new_path"
}

ensure_not_root() {
  if [[ "${EUID}" -eq 0 ]]; then
    warn "Do not run ./bin/bootstrap with sudo or as root."
    warn "Run: ./bin/bootstrap"
    warn "The script will ask for sudo only when a specific privileged step needs it."
    exit 1
  fi
}

ensure_admin_user() {
  if id -Gn | tr ' ' '\n' | grep -qx admin; then
    return 0
  fi

  warn "Homebrew needs sudo access on macOS."
  warn "Add this user to the admin group or run setup from an administrator account."
  exit 1
}

ensure_xcode_command_line_tools() {
  if xcode-select -p >/dev/null 2>&1; then
    log "Xcode Command Line Tools are installed"
    return 0
  fi

  warn "Xcode Command Line Tools are required before bootstrap can continue."
  log "Opening the Xcode Command Line Tools installer"
  xcode-select --install >/dev/null 2>&1 || {
    warn "The installer may already be open. If not, run: xcode-select --install"
  }

  cat <<'EOF'

Finish the Xcode Command Line Tools installer popup, then rerun:

  ./bin/setup
EOF
  exit 0
}

ensure_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    log "Homebrew is installed"
    return 0
  fi

  if [[ -x /opt/homebrew/bin/brew || -x /usr/local/bin/brew ]]; then
    log "Homebrew is installed but not on PATH"
    return 0
  fi

  log "Installing Homebrew"
  warn "Homebrew may ask for your macOS password to create its install directories."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

load_homebrew_shellenv() {
  if [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/brew" ]]; then
    eval "$("${HOMEBREW_PREFIX}/bin/brew" shellenv)"
    return 0
  fi

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    return 0
  fi

  if [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
    return 0
  fi

  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
    return 0
  fi

  warn "Homebrew installed, but brew was not found on PATH."
  exit 1
}

cask_app_bundle_name() {
  case "$1" in
    beeper) printf 'Beeper' ;;
    blackhole-2ch) printf 'BlackHole 2ch' ;;
    chatgpt) printf 'ChatGPT' ;;
    claude) printf 'Claude' ;;
    cursor) printf 'Cursor' ;;
    cyberduck) printf 'Cyberduck' ;;
    discord) printf 'Discord' ;;
    expo-orbit) printf 'Orbit' ;;
    figma) printf 'Figma' ;;
    font-hack-nerd-font) printf '' ;;
    ghostty) printf 'Ghostty' ;;
    google-chrome) printf 'Google Chrome' ;;
    helium-browser) printf 'Helium' ;;
    iina) printf 'IINA' ;;
    iterm2) printf 'iTerm' ;;
    karabiner-elements) printf 'Karabiner-Elements' ;;
    mole-app) printf 'Mole' ;;
    multipass) printf 'Multipass' ;;
    neardrop | grishka/grishka/neardrop) printf 'NearDrop' ;;
    ngrok) printf 'ngrok' ;;
    nikitabobko/tap/aerospace | aerospace) printf 'AeroSpace' ;;
    notion-calendar) printf 'Notion Calendar' ;;
    obsidian) printf 'Obsidian' ;;
    orbstack) printf 'OrbStack' ;;
    pgadmin4) printf 'pgAdmin 4' ;;
    raycast) printf 'Raycast' ;;
    rectangle) printf 'Rectangle' ;;
    signal) printf 'Signal' ;;
    slack) printf 'Slack' ;;
    spotify) printf 'Spotify' ;;
    stats) printf 'Stats' ;;
    superwhisper) printf 'superwhisper' ;;
    synology-drive) printf 'Synology Drive Client' ;;
    t3-code) printf 'T3 Code (Alpha)' ;;
    tailscale-app) printf 'Tailscale' ;;
    the-unarchiver) printf 'The Unarchiver' ;;
    visual-studio-code) printf 'Visual Studio Code' ;;
    warp) printf 'Warp' ;;
    whatsapp) printf 'WhatsApp' ;;
    yaak) printf 'Yaak' ;;
    zen) printf 'Zen' ;;
    zoom) printf 'zoom.us' ;;
    zulu@17) printf '' ;;
    *) printf '' ;;
  esac
}

mas_app_bundle_name() {
  case "$1" in
    Amphetamine) printf 'Amphetamine' ;;
    "Draw Things") printf 'Draw Things' ;;
    SiteSucker) printf 'SiteSucker' ;;
    TestFlight) printf 'TestFlight' ;;
    "The Unarchiver") printf 'The Unarchiver' ;;
    WhatsApp) printf 'WhatsApp' ;;
    *) printf '%s' "$1" ;;
  esac
}

preferred_xcode_developer_dir() {
  local app

  if [[ -d "/Applications/Xcode.app/Contents/Developer" ]]; then
    printf '/Applications/Xcode.app/Contents/Developer\n'
    return 0
  fi

  while IFS= read -r app; do
    if [[ -d "${app}/Contents/Developer" ]]; then
      printf '%s/Contents/Developer\n' "$app"
      return 0
    fi
  done < <(ls -dt /Applications/Xcode*.app 2>/dev/null || true)

  return 1
}

full_xcode_selected() {
  local developer_dir

  developer_dir="$(preferred_xcode_developer_dir || true)"
  [[ -n "$developer_dir" && "$(xcode-select -p 2>/dev/null || true)" == "$developer_dir" ]]
}

full_xcode_dependent_formula() {
  case "$1" in
    facebook/fb/idb-companion | idb-companion | sourcekitten | wix/brew/applesimutils | applesimutils)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

homebrew_xcode_sensitive_formula() {
  case "$1" in
    borders | facebook/fb/idb-companion | idb-companion | sourcekitten | wix/brew/applesimutils | applesimutils)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

homebrew_reports_xcode_too_old() {
  local doctor_output

  if [[ "$homebrew_xcode_checked" -eq 1 ]]; then
    [[ "$homebrew_xcode_too_old" -eq 1 ]]
    return $?
  fi

  homebrew_xcode_checked=1

  if ! command -v brew >/dev/null 2>&1; then
    return 1
  fi

  doctor_output="$(brew doctor 2>&1 || true)"
  if grep -q 'Your Xcode .* is too outdated' <<< "$doctor_output"; then
    homebrew_xcode_too_old=1
    return 0
  fi

  return 1
}

ensure_mise_cli() {
  prepend_mise_shims
  "${repo_root}/bin/ensure-mise-standalone" || return 1
  prepend_mise_shims
  hash -r
  command -v mise >/dev/null 2>&1
}

ensure_mas_cli() {
  prepend_mise_shims

  if command -v mas >/dev/null 2>&1; then
    return 0
  fi

  if command -v mise >/dev/null 2>&1; then
    log "Installing mas with mise"
    (cd "$repo_root" && mise install mas@latest && mise reshim)
    prepend_mise_shims
    hash -r
    if command -v mas >/dev/null 2>&1; then
      return 0
    fi
  fi

  log "Installing mas"
  brew install mas
  hash -r
  command -v mas >/dev/null 2>&1
}

mas_available_for_brewfile() {
  if [[ $mas_checked -eq 1 ]]; then
    [[ $mas_available -eq 1 ]]
    return $?
  fi

  mas_checked=1

  if ! command -v mas >/dev/null 2>&1; then
    warn "Skipping Mac App Store apps; mas will be installed by Homebrew. Rerun ./bin/setup after signing in to the App Store."
    return 1
  fi

  if mas config >/dev/null 2>&1; then
    mas_available=1
    return 0
  fi

  warn "Skipping Mac App Store apps; mas is installed but the App Store is not usable yet. Sign in, then rerun ./bin/setup."
  return 1
}

mas_app_installed() {
  local app_id="$1"

  mas list | awk '{print $1}' | grep -Fxq "$app_id"
}

install_mas_apps() {
  local line app_name app_id app_bundle status=0

  if [[ ! -s "$mas_brewfile" ]]; then
    return 0
  fi

  if ! mas_available_for_brewfile; then
    runtime_record_deferred "Mac App Store apps" "mas is unavailable or App Store is not signed in" "Sign in to the App Store, then rerun ./bin/setup."
    return 0
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^mas[[:space:]]+\"([^\"]+)\"\,\ id:\ ([0-9]+) ]]; then
      app_name="${BASH_REMATCH[1]}"
      app_id="${BASH_REMATCH[2]}"
      app_bundle="$(mas_app_bundle_name "$app_name")"

      if [[ -d "/Applications/${app_bundle}.app" ]]; then
        log "${app_bundle}.app already exists"
        continue
      fi

      if mas_app_installed "$app_id"; then
        log "App Store app ${app_name} already installed"
        continue
      fi

      log "Installing App Store app ${app_name}"
      mas install "$app_id" || {
        warn "Skipping ${app_name}; App Store did not start the download. Open it in the App Store once, then rerun ./bin/setup."
        runtime_record_failure recoverable "App Store app ${app_name}" "mas install did not start the download" "" "Open ${app_name} in the App Store once, then rerun ./bin/setup."
        status=1
      }
    fi
  done < "$mas_brewfile"

  return "$status"
}

code_cli() {
  if command -v code >/dev/null 2>&1; then
    command -v code
    return 0
  fi

  if [[ -x "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" ]]; then
    printf '/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\n'
    return 0
  fi

  return 1
}

install_vscode_extensions() {
  local code_cmd line extension_id installed_extensions status=0

  if [[ ! -s "$vscode_brewfile" ]]; then
    return 0
  fi

  code_cmd="$(code_cli || true)"
  if [[ -z "$code_cmd" ]]; then
    warn "Skipped VS Code extensions; code CLI is not available yet"
    runtime_record_deferred "VS Code extensions" "code CLI is not available yet" "Open VS Code once or rerun ./bin/setup after the cask install completes."
    return 0
  fi

  installed_extensions="$("$code_cmd" --list-extensions 2>/dev/null || true)"

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^vscode[[:space:]]+\"([^\"]+)\" ]]; then
      extension_id="${BASH_REMATCH[1]}"

      if grep -Fixq "$extension_id" <<< "$installed_extensions"; then
        log "VS Code extension ${extension_id} already installed"
        continue
      fi

      log "Installing VS Code extension ${extension_id}"
      "$code_cmd" --install-extension "$extension_id" || {
        warn "Skipping VS Code extension ${extension_id}; it is unavailable or failed to install"
        runtime_record_failure recoverable "VS Code extension ${extension_id}" "extension install failed" "" "Rerun ./bin/setup after VS Code is ready."
        status=1
      }
    fi
  done < "$vscode_brewfile"

  return "$status"
}

untap_if_present() {
  local tap="$1"
  local replacement="$2"

  if ! brew tap | grep -Fxq "$tap"; then
    return 0
  fi

  warn "Untapping legacy Homebrew tap ${tap}; ${replacement} is the managed source"
  brew untap --force "$tap" || warn "Could not untap ${tap}; Homebrew may still report duplicate formulae"
}

normalize_homebrew_taps() {
  untap_if_present "zegervdv/zathura" "homebrew-zathura/zathura"
}

legacy_zathura_receipts_present() {
  local formula cellar receipt
  local formulae=(
    zathura-cb
    zathura-pdf-mupdf
  )

  for formula in "${formulae[@]}"; do
    cellar="$(brew --cellar "$formula" 2>/dev/null || true)"
    [[ -d "$cellar" ]] || continue

    while IFS= read -r receipt; do
      if grep -q 'zegervdv/zathura' "$receipt"; then
        return 0
      fi
    done < <(find "$cellar" -name INSTALL_RECEIPT.json -print 2>/dev/null)
  done

  return 1
}

repair_legacy_zathura_receipts() {
  if ! legacy_zathura_receipts_present; then
    return 0
  fi

  warn "Reinstalling zathura plugins to update legacy Homebrew receipt metadata"
  brew reinstall --formula \
    homebrew-zathura/zathura/zathura-cb \
    homebrew-zathura/zathura/zathura-pdf-mupdf || \
    warn "Could not update zathura plugin receipts; Homebrew may keep warning about the old zegervdv/zathura tap"
}

filter_brewfile_for_existing_apps() {
  local source_file="$1"
  local target_file="$2"
  local deferred_xcode_file="$3"
  local mas_file="$4"
  local vscode_file="$5"
  local line brew_name cask_name app_name mas_name mas_id mas_bundle

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^brew[[:space:]]+\"([^\"]+)\" ]]; then
      brew_name="${BASH_REMATCH[1]}"

      if full_xcode_dependent_formula "$brew_name" && ! full_xcode_selected; then
        warn "Deferring ${brew_name}; full Xcode is required"
        printf '# Deferred until full Xcode is selected: %s\n' "$line" >> "$target_file"
        printf '%s\n' "$line" >> "$deferred_xcode_file"
        continue
      fi

      if homebrew_xcode_sensitive_formula "$brew_name"; then
        if homebrew_reports_xcode_too_old; then
          warn "Deferring ${brew_name}; Homebrew requires a newer Xcode app"
          printf '# Deferred until Homebrew accepts the installed Xcode app: %s\n' "$line" >> "$target_file"
          printf '%s\n' "$line" >> "$deferred_xcode_file"
          continue
        fi
      fi
    fi

    if [[ "$line" =~ ^mas[[:space:]]+\"([^\"]+)\"\,\ id:\ ([0-9]+) ]]; then
      mas_name="${BASH_REMATCH[1]}"
      mas_id="${BASH_REMATCH[2]}"
      mas_bundle="$(mas_app_bundle_name "$mas_name")"

      printf '# Installed separately by bootstrap: %s\n' "$line" >> "$target_file"

      if [[ -d "/Applications/${mas_bundle}.app" ]]; then
        warn "Skipping App Store app ${mas_name}; /Applications/${mas_bundle}.app already exists"
        continue
      elif command -v mas >/dev/null 2>&1 && mas_app_installed "$mas_id"; then
        warn "Skipping App Store app ${mas_name}; already installed"
        continue
      fi

      printf '%s\n' "$line" >> "$mas_file"
      continue
    fi

    if [[ "$line" =~ ^vscode[[:space:]]+\"([^\"]+)\" ]]; then
      printf '# Installed separately by bootstrap: %s\n' "$line" >> "$target_file"
      printf '%s\n' "$line" >> "$vscode_file"
      continue
    fi

    if [[ "$line" =~ ^cask[[:space:]]+\"([^\"]+)\" ]]; then
      cask_name="${BASH_REMATCH[1]}"
      app_name="$(cask_app_bundle_name "$cask_name")"

      if [[ -n "$app_name" && -d "/Applications/${app_name}.app" ]]; then
        warn "Skipping cask ${cask_name}; /Applications/${app_name}.app already exists"
        printf '# Skipped existing app: %s\n' "$line" >> "$target_file"
        continue
      fi
    fi

    printf '%s\n' "$line" >> "$target_file"
  done < "$source_file"
}

install_brewfile() {
  temp_brewfile="$(mktemp)"
  xcode_brewfile="$(mktemp)"
  mas_brewfile="$(mktemp)"
  vscode_brewfile="$(mktemp)"

  normalize_homebrew_taps
  repair_legacy_zathura_receipts
  ensure_mas_cli || true
  filter_brewfile_for_existing_apps "${repo_root}/Brewfile" "$temp_brewfile" "$xcode_brewfile" "$mas_brewfile" "$vscode_brewfile"

  if "${repo_root}/bin/configure-sudo-touch-id" --check >/dev/null 2>&1; then
    log "Touch ID for sudo is enabled"
  else
    warn "Touch ID for sudo is not enabled yet; the next sudo prompt will require your password."
  fi

  log "Refreshing sudo timestamp for Homebrew cask installs"
  sudo -v

  log "Starting background sudo keepalive"
  (while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null) &
  sudo_keepalive_pid=$!

  log "Installing Homebrew bundle with ${brew_bundle_jobs} parallel job(s)"
  brew bundle install --jobs="$brew_bundle_jobs" --no-upgrade --verbose --file "$temp_brewfile"
}

install_post_brew_apps() {
  runtime_run_job "Mac App Store apps" recoverable \
    "Sign in to the App Store, then rerun ./bin/setup." \
    install_mas_apps
  runtime_run_job "VS Code extensions" recoverable \
    "Open VS Code once or rerun ./bin/setup after the cask install completes." \
    install_vscode_extensions

  runtime_wait_jobs
}

mobile_dev_ready() {
  full_xcode_selected &&
    [[ -d "/Applications/Android Studio.app" ]] &&
    brew list --formula "facebook/fb/idb-companion" >/dev/null 2>&1 &&
    brew list --formula "sourcekitten" >/dev/null 2>&1 &&
    brew list --formula "wix/brew/applesimutils" >/dev/null 2>&1
}

report_mobile_dev_deferred() {
  if mobile_dev_ready; then
    log "Mobile dev stack is already installed"
    return 0
  fi

  warn "Mobile dev stack is deferred. Run ./bin/install-mobile-dev for full Xcode, Android Studio, applesimutils, idb-companion, and sourcekitten."
}

initialize_submodules() {
  log "Initializing git submodules"
  git -C "$repo_root" submodule sync --recursive
  git -C "$repo_root" submodule update --init --recursive || {
    warn "Submodule init failed. Check network access and rerun: git submodule update --init --recursive"
    return 1
  }
}

install_mise_tools() {
  prepend_mise_shims

  if ! command -v mise >/dev/null 2>&1; then
    warn "mise is not available; cannot install mise tools"
    return 1
  fi

  log "Installing mise tools"
  (cd "$repo_root" && mise install && mise reshim)
}

install_and_check_mise_tools() {
  install_mise_tools || return 1
  "${repo_root}/bin/check-mise-tools"
}

install_shell_framework() {
  local omz_dir="${HOME}/.oh-my-zsh"
  local custom_dir="${ZSH_CUSTOM:-${omz_dir}/custom}"
  local p10k_dir="${custom_dir}/themes/powerlevel10k"
  local autosuggestions_dir="${custom_dir}/plugins/zsh-autosuggestions"
  local fzf_history_dir="${custom_dir}/plugins/zsh-fzf-history-search"

  if [[ ! -d "$omz_dir" ]]; then
    log "Installing Oh My Zsh"
    git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git "$omz_dir"
  else
    log "Oh My Zsh is already installed"
  fi

  if [[ ! -d "$p10k_dir" ]]; then
    log "Installing Powerlevel10k"
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$p10k_dir"
  else
    log "Powerlevel10k is already installed"
  fi

  if [[ ! -d "$autosuggestions_dir" ]]; then
    log "Installing zsh-autosuggestions"
    git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions.git "$autosuggestions_dir"
  else
    log "zsh-autosuggestions is already installed"
  fi

  if [[ ! -d "$fzf_history_dir" ]]; then
    log "Installing zsh-fzf-history-search"
    git clone --depth=1 https://github.com/joshskidmore/zsh-fzf-history-search.git "$fzf_history_dir"
  else
    log "zsh-fzf-history-search is already installed"
  fi
}

apply_macos_defaults_once() {
  local defaults_script="${repo_root}/macos/defaults.sh"
  local status=0

  runtime_acquire_lock "macos-defaults" "macOS defaults" || return 1

  if [[ "${DOTFILES_SKIP_MACOS_DEFAULTS:-}" == "1" ]]; then
    warn "Skipping macOS defaults because DOTFILES_SKIP_MACOS_DEFAULTS=1"
    runtime_release_lock "macos-defaults"
    return 0
  fi

  if [[ -f "$macos_defaults_flag" && ! "$defaults_script" -nt "$macos_defaults_flag" ]]; then
    log "macOS defaults already applied"
    runtime_release_lock "macos-defaults"
    return 0
  fi

  log "Applying macOS defaults"
  set +e
  "$defaults_script"
  status=$?
  set -e
  if [[ "$status" -eq 0 ]]; then
    touch "$macos_defaults_flag"
  fi
  runtime_release_lock "macos-defaults"
  return "$status"
}

if ! runtime_acquire_global_lock; then
  if [[ "${DOTFILES_RUNTIME_OWNS_SUMMARY:-0}" -eq 1 ]]; then
    runtime_print_summary
  fi
  exit 1
fi
ensure_not_root
ensure_admin_user
if [[ "${DOTFILES_SKIP_SUDO_TOUCH_ID:-}" == "1" ]]; then
  warn "Skipping Touch ID sudo setup because DOTFILES_SKIP_SUDO_TOUCH_ID=1"
  runtime_record_deferred "Touch ID sudo" "skipped because DOTFILES_SKIP_SUDO_TOUCH_ID=1" "Run ./bin/configure-sudo-touch-id --enable later."
else
  log "Configuring Touch ID for sudo"
  if "${repo_root}/bin/configure-sudo-touch-id" --enable; then
    runtime_record_completed "Touch ID sudo"
  else
    warn "Touch ID sudo setup was skipped; run ./bin/configure-sudo-touch-id --enable after setup."
    runtime_record_failure recoverable "Touch ID sudo" "configuration failed or was skipped" "" "Run ./bin/configure-sudo-touch-id --enable after setup."
    bootstrap_status=1
  fi
fi
ensure_xcode_command_line_tools
ensure_homebrew
load_homebrew_shellenv
ensure_mise_cli
if initialize_submodules; then
  runtime_record_completed "Git submodules"
else
  runtime_record_failure recoverable "Git submodules" "submodule init failed" "" "Rerun git submodule update --init --recursive."
  bootstrap_status=1
fi

log "Linking dotfiles"
if "${repo_root}/bin/link-dotfiles"; then
  runtime_record_completed "Dotfile links"
else
  runtime_record_failure recoverable "Dotfile links" "link-dotfiles failed" "" "Rerun ./bin/link-dotfiles."
  bootstrap_status=1
fi

log "Ensuring Codex standalone install"
if "${repo_root}/bin/ensure-codex-standalone"; then
  runtime_record_completed "Codex standalone install"
else
  runtime_record_failure recoverable "Codex standalone install" "standalone Codex setup failed" "" "Rerun ./bin/ensure-codex-standalone after checking the logged error."
  bootstrap_status=1
fi

log "Ensuring Cursor Agent standalone install"
if "${repo_root}/bin/ensure-cursor-agent-standalone"; then
  runtime_record_completed "Cursor Agent standalone install"
else
  runtime_record_failure recoverable "Cursor Agent standalone install" "standalone Cursor Agent setup failed" "" "Rerun ./bin/ensure-cursor-agent-standalone after checking the logged error."
  bootstrap_status=1
fi

if [[ "$mobile_dev_enabled" -eq 1 ]]; then
  if "${repo_root}/bin/install-mobile-dev" --prepare-tools-only; then
    runtime_record_completed "Mobile dev download tools" "xcodes and aria2 are ready"
    runtime_run_job "Xcode install" recoverable \
      "Sign in to Apple Developer if prompted, then rerun ./bin/setup." \
      "${repo_root}/bin/install-mobile-dev" --xcode-install-only
  else
    runtime_record_failure recoverable "Mobile dev download tools" "could not prepare xcodes and aria2" "" "Rerun ./bin/install-mobile-dev --prepare-tools-only after checking mise/network access."
    bootstrap_status=1
  fi
else
  runtime_record_deferred "Mobile dev stack" "skipped because DOTFILES_SKIP_MOBILE_DEV=1" "Rerun ./bin/setup without DOTFILES_SKIP_MOBILE_DEV=1."
fi

ensure_mas_cli || runtime_record_deferred "mas CLI" "mas could not be installed yet" "Rerun ./bin/setup after mise or Homebrew is ready."
runtime_run_job "mise tools" recoverable \
  "Rerun cd ${repo_root} && mise install, then ./bin/check-mise-tools." \
  install_and_check_mise_tools

if install_brewfile; then
  runtime_record_completed "Homebrew bundle"
else
  runtime_record_failure recoverable "Homebrew bundle" "brew bundle failed" "" "Rerun ./bin/bootstrap after fixing the Homebrew error."
  bootstrap_status=1
fi

if [[ "$mobile_dev_enabled" -eq 1 ]]; then
  runtime_run_job "Android Studio" recoverable \
    "Rerun ./bin/install-mobile-dev, or install Android Studio with brew install --cask android-studio." \
    "${repo_root}/bin/install-mobile-dev" --android-only
fi

if ! install_post_brew_apps; then
  bootstrap_status=1
fi

log "Linking app dotfiles"
if "${repo_root}/bin/link-dotfiles"; then
  runtime_record_completed "App dotfile links"
else
  runtime_record_failure recoverable "App dotfile links" "link-dotfiles failed after app install" "" "Rerun ./bin/link-dotfiles."
  bootstrap_status=1
fi

if [[ "$mobile_dev_enabled" -eq 1 ]]; then
  if full_xcode_selected; then
    runtime_run_job "iOS platform support" recoverable \
      "Open Xcode > Settings > Components and install iOS, then rerun ./bin/install-mobile-dev." \
      "${repo_root}/bin/install-mobile-dev" --ios-platform-only
    runtime_run_job "Xcode-dependent Homebrew formulae" recoverable \
      "Rerun ./bin/install-mobile-dev after Xcode is selected." \
      "${repo_root}/bin/install-mobile-dev" --xcode-formulae-only
    if ! runtime_wait_jobs; then
      bootstrap_status=1
    fi
  else
    runtime_record_failure recoverable "Mobile dev post-Xcode" "full Xcode is not selected" "" "Fix Xcode install, then rerun ./bin/install-mobile-dev."
    bootstrap_status=1
  fi
else
  report_mobile_dev_deferred
fi

runtime_run_job "tmux plugins" recoverable \
  "Rerun ./bin/setup-tmux after network access is ready." \
  "${repo_root}/bin/setup-tmux"
runtime_run_job "shell framework" recoverable \
  "Rerun ./bin/bootstrap after network access is ready." \
  install_shell_framework
if ! runtime_wait_jobs; then
  bootstrap_status=1
fi

if apply_macos_defaults_once; then
  runtime_record_completed "macOS defaults"
else
  runtime_record_failure recoverable "macOS defaults" "defaults script failed" "" "Rerun ./bin/bootstrap or DOTFILES_SKIP_MACOS_DEFAULTS=1 ./bin/bootstrap."
  bootstrap_status=1
fi

log "Configuring Finder sidebar favorites"
if "${repo_root}/bin/finder-sidebar-favorites"; then
  runtime_record_completed "Finder sidebar favorites"
else
  warn "Finder sidebar favorite setup failed; rerun ./bin/finder-sidebar-favorites after Finder permissions are ready"
  runtime_record_failure recoverable "Finder sidebar favorites" "Finder sidebar setup failed" "" "Rerun ./bin/finder-sidebar-favorites after Finder permissions are ready."
  bootstrap_status=1
fi

cat <<'EOF'

Bootstrap complete.

Recommended next steps:
- Open a new terminal, or reload this one with: source "$HOME/.zshrc"
- Run ./bin/auth-setup to configure SSH and GitHub access.
- Run ./bin/install-apps to install extra casks and report manual vendor apps.
- Sign in to Apple ID, App Store, and iCloud.
- Re-grant Accessibility / Automation / network permissions for Karabiner, AeroSpace, NearDrop, Synology Drive, superwhisper, and similar tools.
- Finish first-run setup for Xcode, Android Studio, OrbStack, and DaVinci Resolve after installing the apps.
EOF

if [[ "${DOTFILES_RUNTIME_OWNS_SUMMARY:-0}" -eq 1 ]]; then
  runtime_print_summary
fi

if [[ "$bootstrap_status" -ne 0 ]]; then
  exit "$bootstrap_status"
fi
if [[ "${DOTFILES_RUNTIME_OWNS_SUMMARY:-0}" -eq 1 ]]; then
  runtime_exit_status
fi
exit 0
