#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
macos_defaults_flag="${HOME}/.macos-defaults-applied"
temp_brewfile=""
sudo_keepalive_pid=""
mas_checked=0
mas_available=0

cleanup() {
  if [[ -n "$temp_brewfile" ]]; then
    rm -f "$temp_brewfile"
  fi

  if [[ -n "$sudo_keepalive_pid" ]]; then
    kill "$sudo_keepalive_pid" 2>/dev/null || true
    wait "$sudo_keepalive_pid" 2>/dev/null || true
  fi
}

trap cleanup EXIT

log() {
  printf '==> %s\n' "$1"
}

warn() {
  printf '!! %s\n' "$1" >&2
}

ensure_not_root() {
  if [[ "${EUID}" -eq 0 ]]; then
    warn "Do not run ./bin/bootstrap with sudo or as root."
    warn "Run: ./bin/bootstrap"
    warn "The script will ask for sudo only when a specific privileged step needs it."
    exit 1
  fi
}

ensure_admin_user() {
  if id -Gn | tr ' ' '\n' | grep -qx admin; then
    return 0
  fi

  warn "Homebrew needs sudo access on macOS."
  warn "Add this user to the admin group or run setup from an administrator account."
  exit 1
}

ensure_xcode_command_line_tools() {
  if xcode-select -p >/dev/null 2>&1; then
    log "Xcode Command Line Tools are installed"
    return 0
  fi

  warn "Xcode Command Line Tools are required before bootstrap can continue."
  log "Opening the Xcode Command Line Tools installer"
  xcode-select --install >/dev/null 2>&1 || {
    warn "The installer may already be open. If not, run: xcode-select --install"
  }

  cat <<'EOF'

Finish the Xcode Command Line Tools installer popup, then rerun:

  ./bin/setup
EOF
  exit 0
}

ensure_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    log "Homebrew is installed"
    return 0
  fi

  log "Installing Homebrew"
  warn "Homebrew may ask for your macOS password to create its install directories."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

load_homebrew_shellenv() {
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    return 0
  fi

  if [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
    return 0
  fi

  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
    return 0
  fi

  warn "Homebrew installed, but brew was not found on PATH."
  exit 1
}

cask_app_bundle_name() {
  case "$1" in
    beeper) printf 'Beeper' ;;
    blackhole-2ch) printf 'BlackHole 2ch' ;;
    chatgpt) printf 'ChatGPT' ;;
    claude) printf 'Claude' ;;
    codex) printf 'Codex' ;;
    cursor) printf 'Cursor' ;;
    cyberduck) printf 'Cyberduck' ;;
    discord) printf 'Discord' ;;
    expo-orbit) printf 'Orbit' ;;
    figma) printf 'Figma' ;;
    font-hack-nerd-font) printf '' ;;
    ghostty) printf 'Ghostty' ;;
    google-chrome) printf 'Google Chrome' ;;
    helium-browser) printf 'Helium' ;;
    iina) printf 'IINA' ;;
    iterm2) printf 'iTerm' ;;
    karabiner-elements) printf 'Karabiner-Elements' ;;
    mole-app) printf 'Mole' ;;
    multipass) printf 'Multipass' ;;
    neardrop | grishka/grishka/neardrop) printf 'NearDrop' ;;
    ngrok) printf 'ngrok' ;;
    nikitabobko/tap/aerospace | aerospace) printf 'AeroSpace' ;;
    notion-calendar) printf 'Notion Calendar' ;;
    obsidian) printf 'Obsidian' ;;
    orbstack) printf 'OrbStack' ;;
    pgadmin4) printf 'pgAdmin 4' ;;
    raycast) printf 'Raycast' ;;
    rectangle) printf 'Rectangle' ;;
    signal) printf 'Signal' ;;
    slack) printf 'Slack' ;;
    spotify) printf 'Spotify' ;;
    stats) printf 'Stats' ;;
    superwhisper) printf 'superwhisper' ;;
    synology-drive) printf 'Synology Drive Client' ;;
    t3-code) printf 'T3 Code (Alpha)' ;;
    tailscale-app) printf 'Tailscale' ;;
    the-unarchiver) printf 'The Unarchiver' ;;
    visual-studio-code) printf 'Visual Studio Code' ;;
    warp) printf 'Warp' ;;
    whatsapp) printf 'WhatsApp' ;;
    yaak) printf 'Yaak' ;;
    zen) printf 'Zen' ;;
    zoom) printf 'zoom.us' ;;
    zulu@17) printf '' ;;
    *) printf '' ;;
  esac
}

mas_available_for_brewfile() {
  if [[ $mas_checked -eq 1 ]]; then
    [[ $mas_available -eq 1 ]]
    return $?
  fi

  mas_checked=1

  if ! command -v mas >/dev/null 2>&1; then
    warn "Skipping Mac App Store apps; mas will be installed by Homebrew. Rerun ./bin/setup after signing in to the App Store."
    return 1
  fi

  if mas config >/dev/null 2>&1; then
    mas_available=1
    return 0
  fi

  warn "Skipping Mac App Store apps; mas is installed but the App Store is not usable yet. Sign in, then rerun ./bin/setup."
  return 1
}

filter_brewfile_for_existing_apps() {
  local source_file="$1"
  local target_file="$2"
  local line cask_name app_name

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^mas[[:space:]]+\"([^\"]+)\" ]]; then
      if ! mas_available_for_brewfile; then
        printf '# Skipped until App Store is signed in: %s\n' "$line" >> "$target_file"
        continue
      fi
    fi

    if [[ "$line" =~ ^cask[[:space:]]+\"([^\"]+)\" ]]; then
      cask_name="${BASH_REMATCH[1]}"
      app_name="$(cask_app_bundle_name "$cask_name")"

      if [[ -n "$app_name" && -d "/Applications/${app_name}.app" ]]; then
        warn "Skipping cask ${cask_name}; /Applications/${app_name}.app already exists"
        printf '# Skipped existing app: %s\n' "$line" >> "$target_file"
        continue
      fi
    fi

    printf '%s\n' "$line" >> "$target_file"
  done < "$source_file"
}

install_brewfile() {
  temp_brewfile="$(mktemp)"

  filter_brewfile_for_existing_apps "${repo_root}/Brewfile" "$temp_brewfile"

  log "Refreshing sudo timestamp for Homebrew cask installs"
  sudo -v

  log "Starting background sudo keepalive"
  (while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null) &
  sudo_keepalive_pid=$!

  log "Installing Homebrew bundle"
  brew bundle install --no-upgrade --verbose --file "$temp_brewfile"

  kill "$sudo_keepalive_pid" 2>/dev/null || true
  wait "$sudo_keepalive_pid" 2>/dev/null || true
  sudo_keepalive_pid=""
}

remove_neardrop_quarantine() {
  local app_path="/Applications/NearDrop.app"

  if [[ ! -d "$app_path" ]]; then
    return 0
  fi

  log "Removing NearDrop quarantine attribute"
  sudo xattr -r -d com.apple.quarantine "$app_path" 2>/dev/null || true
}

initialize_submodules() {
  log "Initializing git submodules"
  git -C "$repo_root" submodule sync --recursive
  git -C "$repo_root" submodule update --init --recursive || {
    warn "Submodule init failed. Check network access and rerun: git submodule update --init --recursive"
    return 1
  }
}

install_mise_tools() {
  if ! command -v mise >/dev/null 2>&1; then
    warn "mise is not available after brew bundle; skipping mise install"
    return 0
  fi

  log "Installing mise tools"
  (cd "$repo_root" && mise install)
}

install_shell_framework() {
  local omz_dir="${HOME}/.oh-my-zsh"
  local p10k_dir="${ZSH_CUSTOM:-${omz_dir}/custom}/themes/powerlevel10k"

  if [[ ! -d "$omz_dir" ]]; then
    log "Installing Oh My Zsh"
    git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git "$omz_dir"
  else
    log "Oh My Zsh is already installed"
  fi

  if [[ ! -d "$p10k_dir" ]]; then
    log "Installing Powerlevel10k"
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$p10k_dir"
  else
    log "Powerlevel10k is already installed"
  fi
}

apply_macos_defaults_once() {
  if [[ "${DOTFILES_SKIP_MACOS_DEFAULTS:-}" == "1" ]]; then
    warn "Skipping macOS defaults because DOTFILES_SKIP_MACOS_DEFAULTS=1"
    return 0
  fi

  if [[ -f "$macos_defaults_flag" ]]; then
    log "macOS defaults already applied"
    return 0
  fi

  log "Applying macOS defaults"
  "${repo_root}/macos/defaults.sh"
  touch "$macos_defaults_flag"
}

ensure_not_root
ensure_admin_user
ensure_xcode_command_line_tools
ensure_homebrew
load_homebrew_shellenv
initialize_submodules
install_brewfile
remove_neardrop_quarantine
install_shell_framework

log "Linking dotfiles"
"${repo_root}/bin/link-dotfiles"

install_mise_tools
apply_macos_defaults_once

cat <<'EOF'

Bootstrap complete.

Recommended next steps:
- Run ./bin/auth-setup to configure SSH and GitHub access.
- Run ./bin/install-apps to install extra casks and report manual vendor apps.
- Sign in to Apple ID, App Store, and iCloud.
- Re-grant Accessibility / Automation / network permissions for Karabiner, AeroSpace, NearDrop, Synology Drive, superwhisper, and similar tools.
- Finish first-run setup for Xcode, Android Studio, OrbStack, and DaVinci Resolve.
EOF
